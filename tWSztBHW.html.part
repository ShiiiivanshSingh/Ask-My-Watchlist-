<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ask Shelf</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;1,9..144,500&family=Work+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>

<div class="marquee">
  <div class="marquee-bulbs" aria-hidden="true"></div>
  <h1>Ask <em>Shelf</em></h1>
  <p class="tagline">{{ movie_count }} watches on file &mdash; ask about any of them</p>
</div>

<main>
  <form id="ask-form" autocomplete="off">
    <input type="text" id="query" placeholder="Did I like Magnolia?" aria-label="Ask a question about your movies">
    <button type="submit">
      <span class="btn-label">Ask</span>
    </button>
  </form>

  <div id="tickets" aria-live="polite"></div>

  <div id="empty-state" class="empty-state">
    <div class="ticket-icon" aria-hidden="true">🎞</div>
    <p>Your ticket stubs will show up here.</p>
    <p class="empty-sub">Try &ldquo;have I watched Parasite?&rdquo; or &ldquo;what did I think of The Thing?&rdquo;</p>
  </div>
</main>

<script src="{{ url_for('static', filename='app.js') }}"></script>
</body>
</html>
